        "models": {
            "ultraFast": "o3",
            "thinking": [
                "claude-4-sonnet-thinking",
                "claude-4-opus-thinking"
            ],
            "multimodal": "gemini-2.5-pro",
            "enhanced": "gpt-4.1",
            "rapid": "claude-3.7-sonnet-thinking"
        },
        "unlimited": {
            "contextProcessing": true,
            "fileSize": "unlimited",
            "projectSize": "unlimited",
