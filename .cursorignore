# Production Optimization Exclusions
# Exclude large log files but keep essential ones
logs/performance/large-dataset-*.log
logs/optimization/benchmark-*.json
logs/revolutionary/stress-test-*.log

# Exclude temporary optimization files
.cursor-optimization-temp/
.revolutionary-cache-temp/
*.optimization.tmp

# Keep essential AI architecture files for context
# lib/ai/ - INCLUDE (needed for production)
# lib/cache/ - INCLUDE (needed for production)  
# lib/system/ - INCLUDE (needed for production)
# scripts/ - INCLUDE (needed for production)
