{
  "name": "cursor-uninstaller",
  "version": "1.0.0",
  "description": "Cursor uninstaller tool for macOS",
  "main": "bin/uninstall_cursor.sh",
  "scripts": {
    "test": "jest --config=jest.config.js --testTimeout=30000",
    "test:integration": "jest tests/integration/",
    "test:all": "npm run test:integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint lib modules tests --ext .ts,.js --fix",
    "lint:check": "eslint lib modules tests --ext .ts,.js",
    "dev": "nodemon --exec 'node --experimental-modules' --ext js,ts,json",
    "performance:monitor": "clinic doctor -- node tests/bench/performance-monitor.js",
    "cache:clear": "rm -rf .cache/* && echo 'Cache cleared'",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "audit:check": "npm audit --audit-level=moderate",
    "security:scan": "npm audit --json > security-audit.json",
    "mcp:validate": "npx @modelcontextprotocol/server-filesystem --help"
  },
  "keywords": [
    "cursor",
    "ai optimization",
    "macos"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "autocannon": "^8.0.0",
    "clinic": "^0.6.2",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "prettier": "^3.5.3",
    "pretty-format": "^29.7.0",
    "ts-jest": "^29.3.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.4.1",
    "puppeteer": "^24.10.0"
  },
  "overrides": {
    "d3-color": ">=3.1.0",
    "d3-interpolate": ">=3.0.1",
    "tough-cookie": ">=4.1.3",
    "request": "/* replace or alias to axios/node-fetch if possible */"
  }
}
