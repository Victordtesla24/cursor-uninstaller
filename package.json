{
  "name": "cursor-uninstaller",
  "version": "1.0.0",
  "description": "Cursor uninstaller tool for macOS",
  "type": "module",
  "main": "bin/uninstall_cursor.sh",
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config=jest.config.enhanced.js --testTimeout=30000",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest tests/integration/ --config=jest.config.enhanced.js",
    "test:all": "npm run test:integration",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch --config=jest.config.enhanced.js",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage --config=jest.config.enhanced.js",
    "lint": "eslint lib modules tests --ext .ts,.js --fix",
    "lint:check": "eslint lib modules tests --ext .ts,.js",
    "dev": "nodemon --exec 'node --experimental-modules' --ext js,ts,json",
    "performance:monitor": "clinic doctor -- node tests/bench/performance-monitor.js",
    "cache:clear": "rm -rf .cache/* && echo 'Cache cleared'",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "audit:check": "npm audit --audit-level=moderate",
    "security:scan": "npm audit --json > security-audit.json",
    "mcp:validate": "npx @modelcontextprotocol/server-filesystem --help",
    "start:monitoring": "bash scripts/start-monitoring.sh",
    "stop:monitoring": "bash scripts/stop-monitoring.sh",
    "dashboard": "open http://localhost:8080/dashboard",
    "optimize": "node scripts/systematic-optimization.js",
    "env:setup": "cp .env.example .env && echo '✅ .env file created! Please edit .env and add your API keys.'",
    "env:check": "node -e \"require('dotenv/config'); console.log('🔍 Environment Check:'); console.log('ANTHROPIC_API_KEY:', process.env.ANTHROPIC_API_KEY ? '✅ Set' : '❌ Missing'); console.log('GOOGLE_AI_API_KEY:', process.env.GOOGLE_AI_API_KEY ? '✅ Set' : '⚠️ Optional'); console.log('OPENAI_API_KEY:', process.env.OPENAI_API_KEY ? '✅ Set' : '⚠️ Optional');\""
  },
  "keywords": [
    "cursor",
    "ai optimization",
    "macos"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "autocannon": "^8.0.0",
    "clinic": "^0.6.2",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "prettier": "^3.5.3",
    "pretty-format": "^29.7.0",
    "ts-jest": "^29.3.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.4.1",
    "dotenv": "^16.5.0",
    "puppeteer": "^24.10.0"
  },
  "overrides": {
    "d3-color": ">=3.1.0",
    "d3-interpolate": ">=3.0.1",
    "tough-cookie": ">=4.1.3",
    "request": "/* replace or alias to axios/node-fetch if possible */"
  }
}
