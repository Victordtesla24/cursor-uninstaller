{
  "name": "cursor-uninstaller",
  "version": "1.0.0",
  "description": "Cursor uninstaller tool with integrated Cline AI dashboard",
  "main": "uninstall_cursor.sh",
  "scripts": {
    "dev": "cd src/dashboard && vite",
    "build": "cd src/dashboard && vite build",
    "preview": "cd src/dashboard && vite preview",
    "test": "jest --config=jest.config.js --testTimeout=30000",
    "test:dashboard": "jest --config=jest.config.js tests/integration/",
    "test:unit": "bats tests/unit/*.bats",
    "test:integration": "jest tests/integration/",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "cd src/dashboard && eslint .",
    "lint:fix": "cd src/dashboard && eslint . --fix"
  },
  "keywords": [
    "cursor",
    "uninstaller",
    "dashboard",
    "cline",
    "ai",
    "macos"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^0.390.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.1",
    "@babel/preset-env": "^7.24.1",
    "@babel/preset-react": "^7.24.1",
    "@eslint/js": "^9.27.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.0",
    "@testing-library/react-hooks": "^7.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "babel-jest": "^29.7.0",
    "chart.js": "^4.4.9",
    "eslint": "^9.27.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "pretty-format": "^29.7.0",
    "vite": "^6.3.5"
  }
}
